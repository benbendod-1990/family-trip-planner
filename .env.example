# ─── Google OAuth (Gmail sync feature) ──────────────────────────────────────
# https://console.cloud.google.com/ → Enable Gmail API → OAuth 2.0 Client ID (Web)
VITE_GOOGLE_CLIENT_ID=your_client_id_here

# ─── Supabase ───────────────────────────────────────────────────────────────
# Project Settings → API
# URL shaped like: https://<project-ref>.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co
# Publishable / anon key — safe to ship to the browser (RLS protects data).
# NEVER put the service_role / sb_secret_ key here.
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# ─── AI backend (Cloudflare Worker) ─────────────────────────────────────────
# Local dev: http://localhost:8787 (from `wrangler dev` in /worker)
# Prod: https://family-trip-planner-api.<your-subdomain>.workers.dev
VITE_AI_BASE_URL=http://localhost:8787
# Optional — only used when the user isn't signed into Supabase.
# Must match SHARED_API_SECRET in worker/.dev.vars.
VITE_AI_SHARED_SECRET=
